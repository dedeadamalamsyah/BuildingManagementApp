@model IEnumerable<BuildingApp.Domain.Entities.Visitor>

@{
    ViewData["Title"] = "Visitor Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people-fill"></i> Visitor Management Dashboard</h2>
        <span class="badge bg-primary">Total: @Model.Count() Visitors</span>
    </div>

    <div class="card mb-4 border-0 shadow-sm bg-light">
        <div class="card-body">
            <h6 class="card-title text-muted mb-3">Filter by Registration Date</h6>
            <form method="get" asp-action="Visitors" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-bold">From Date</label>
                    <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold">To Date</label>
                    <input type="date" name="toDate" class="form-control" value="@ViewBag.ToDate" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary px-4">Filter</button>
                    <a asp-action="Visitors" class="btn btn-outline-secondary px-4">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle bg-white mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Date & Time</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Purpose</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">No visitor records found for this period.</td>
                    </tr>
                }
                @foreach (var v in Model)
                {
                    <tr>
                        <td class="small">@v.RegistrationDate.ToString("dd MMM yyyy HH:mm")</td>
                        <td class="fw-bold">@v.FullName</td>
                        <td>@v.Email</td>
                        <td>@v.PhoneNumber</td>
                        <td>
                            <span class="text-truncate d-inline-block" style="max-width: 150px;" title="@v.Purpose">
                                @v.Purpose
                            </span>
                        </td>
                        <td class="text-center">
                            <span class="badge rounded-pill bg-success">Approved</span>
                        </td>
                        <td class="text-center">
                            <form asp-action="DeleteVisitor" asp-route-id="@v.Id" method="post"
                                  onsubmit="return confirm('Are you sure you want to cancel this registration?')">
                                <button class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash"></i> Cancel
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>